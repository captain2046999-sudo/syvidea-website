---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}
---
<BaseLayout {...Astro.props}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
