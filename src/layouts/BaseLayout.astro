---
import { siteConfig } from '../data/site';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: string;
  twitterCreator?: string;
  jsonLd?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogImage = '/og-default.png',
  canonical,
  ogType = 'website',
  twitterCreator = siteConfig.twitter,
  jsonLd,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const ga4Id = import.meta.env.PUBLIC_GA4_ID;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID;

const defaultJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteConfig.name,
  url: siteConfig.url,
  description: siteConfig.description,
  logo: `${siteConfig.url}/favicon.svg`,
  contactPoint: {
    '@type': 'ContactPoint',
    email: siteConfig.email,
    contactType: 'customer service',
  },
});
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Syvidea" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={siteConfig.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="twitter:creator" content={twitterCreator} />
    <meta name="twitter:site" content={siteConfig.twitter} />

    <!-- Facebook -->
    <meta property="fb:app_id" content={siteConfig.facebook} />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {jsonLd || defaultJsonLd}
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- GA4 -->
    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
      </>
    )}

    <!-- Microsoft Clarity -->
    {clarityId && (
      <script is:inline define:vars={{ clarityId }}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", clarityId);
      </script>
    )}

    <!-- Event Tracking -->
    <script is:inline>
      window.syvideaEvents = [];
      function getSource() {
        if (sessionStorage.getItem('syvidea_source')) {
          return sessionStorage.getItem('syvidea_source');
        }
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('source')) {
          return urlParams.get('source');
        }
        if (document.referrer.includes('google')) {
          return 'google-search';
        }
        if (document.referrer.includes('syvidea.com')) {
          return 'internal';
        }
        return 'direct-entry';
      }
      function setSource(source) {
        sessionStorage.setItem('syvidea_source', source);
      }
      window.syvideaSource = getSource();
      function trackEvent(eventName, data = {}) {
        const event = {
          event: eventName,
          timestamp: new Date().toISOString(),
          path: window.location.pathname,
          source: window.syvideaSource,
          ...data
        };
        window.syvideaEvents.push(event);
        console.log('[Syvidea Track]', event);
        if (window.dataLayer) {
          window.dataLayer.push(event);
        }
        if (window.gtag) {
          window.gtag('event', eventName, {
            ...data,
            source: window.syvideaSource,
            path: window.location.pathname,
            timestamp: event.timestamp
          });
        }
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
