---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import { AnimatedCard, AnimatedText, AnimatedLink, GlowingCard } from '../components/Animated';
---
<PageLayout
  title="Start Here — Syvidea"
  description="Choose how you want to run local AI. Match real workloads with the right workstation configuration across three partner platforms."
>
  <section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32" onload="setSource('start-here')">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="glow-bg top-0 left-1/4 h-96 w-96 bg-neon-purple/20 animate-glow-pulse"></div>
    <div class="glow-bg top-20 right-1/4 h-80 w-80 bg-neon-cyan/15 animate-glow-pulse" style="animation-delay: -2s;"></div>

    <div class="container-page relative">
      <div class="max-w-3xl mx-auto text-center">
        <div class="mb-6 inline-flex">
          <span class="badge">
            <span class="mr-1.5 inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-neon-purple"></span>
            Decision entry point
          </span>
        </div>
        <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          <AnimatedText delay={0.1} class="gradient-text">Start here</AnimatedText>
          <br />
          <AnimatedText delay={0.2} class="text-white">choose how you want to run local AI</AnimatedText>
        </h1>
        <AnimatedText delay={0.3}>
          <p class="mt-6 text-lg text-slate-400 text-balance max-w-2xl mx-auto">
            Syvidea helps you match real local AI workloads with the right workstation configuration across three partner platforms.
          </p>
        </AnimatedText>
      </div>
    </div>
  </section>

  <Section
    eyebrow="Choose your path"
    title="Three ways to get started"
    align="left"
  >
    <div class="grid gap-6 md:grid-cols-3">
      <GlowingCard class="group card-neon" glowColor="purple" delay={0.1}>
        <div class="flex h-full flex-col p-6">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-neon-purple/20">
            <svg class="h-6 w-6 text-neon-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white">I want to run Local LLMs or RAG systems</h3>
          <p class="mt-3 text-sm text-slate-400 flex-1">
            Explore validated use cases and see which workloads map to which hardware configuration.
          </p>
          <div class="mt-5 flex items-center text-sm font-medium">
            <a href="/use-cases" onclick="trackEvent('start_here_click', { path: 'use_cases', action: 'Explore use cases' })" class="text-neon-purple hover:opacity-80 transition-opacity">Explore use cases</a>
            <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </div>
        </div>
      </GlowingCard>

      <GlowingCard class="group card-cyan" glowColor="cyan" delay={0.2}>
        <div class="flex h-full flex-col p-6">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-neon-cyan/20">
            <svg class="h-6 w-6 text-neon-cyan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
              <line x1="9" y1="9" x2="15" y2="9" />
              <line x1="9" y1="15" x2="15" y2="15" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white">I want to build AI agents or development workflows</h3>
          <p class="mt-3 text-sm text-slate-400 flex-1">
            Compare the three partner platforms and understand their optimization focus for different development needs.
          </p>
          <div class="mt-5 flex items-center text-sm font-medium">
            <a href="/workstations" onclick="trackEvent('start_here_click', { path: 'workstations', action: 'Compare workstations' })" class="text-neon-cyan hover:opacity-80 transition-opacity">Compare workstations</a>
            <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </div>
        </div>
      </GlowingCard>

      <GlowingCard class="group card-orange" glowColor="orange" delay={0.3}>
        <div class="flex h-full flex-col p-6">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-neon-orange/20">
            <svg class="h-6 w-6 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white">I want to request a workstation quote</h3>
          <p class="mt-3 text-sm text-slate-400 flex-1">
            Skip the research and submit your requirements directly. We will provide a tailored configuration and quote.
          </p>
          <div class="mt-5 flex items-center text-sm font-medium">
            <a href="/request-quote" onclick="trackEvent('start_here_click', { path: 'request_quote', action: 'Request a quote' })" class="text-neon-orange hover:opacity-80 transition-opacity">Request a quote</a>
            <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </div>
        </div>
      </GlowingCard>
    </div>
  </Section>

  <Section
    eyebrow="Not sure yet?"
    title="Use the recommendation engine"
    subtitle="Answer a few questions about your workload, model size, and preferences. The engine will map your needs to the right hardware."
    align="left"
  >
    <div class="card text-center">
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">
        Map your workload to hardware without spending hours researching specifications.
      </p>
      <div class="mt-8">
        <AnimatedLink href="/recommendation-engine" class="btn-primary inline-flex items-center">
          Try Recommendation Engine
          <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </AnimatedLink>
      </div>
    </div>
  </Section>
</PageLayout>