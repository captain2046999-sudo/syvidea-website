---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/Section.astro';
import ProductMock from '../../components/ProductMock.astro';
import PlatformNotice from '../../components/PlatformNotice.astro';
import { brands } from '../../data/brands';
import { sharedPlatform } from '../../data/platform';
---
<PageLayout
  title="Workstations — Syvidea"
  description="Curated partner workstation options on the AMD Strix Halo / AI Max+ 395 platform. Compare BOSGAME, PELAND, and BITPC configurations."
>
  <PlatformNotice />
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-20"></div>
    <div class="glow-bg top-10 left-1/3 h-96 w-96 bg-neon-purple/20 animate-glow-pulse"></div>
    <div class="glow-bg bottom-10 right-1/3 h-80 w-80 bg-neon-cyan/15 animate-glow-pulse" style="animation-delay:-2s;"></div>

    <div class="container-page relative">
      <div class="mx-auto max-w-3xl text-center">
        <div class="mb-5 flex justify-center">
          <span class="badge">Workstations</span>
        </div>
        <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl gradient-text">
          Curated partner workstation options
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 text-balance">
          All options share the same AMD Strix Halo / AI Max+ 395 platform. Choose the brand option that best matches your chassis, I/O, and supply preferences.
        </p>
      </div>
    </div>
  </section>

  <!-- Shared platform strip -->
  <section class="border-y border-slate-800 bg-dark-900/30">
    <div class="container-page py-10">
      <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div>
          <div class="text-xs font-semibold uppercase tracking-wider text-neon-purple">Shared platform</div>
          <h2 class="mt-1 text-2xl font-bold text-white">{sharedPlatform.name}</h2>
          <p class="mt-1 text-slate-400 max-w-2xl">{sharedPlatform.tagline}</p>
        </div>
        <a href="/workstations/platform" class="btn-secondary shrink-0">
          See full platform spec
          <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How to choose -->
  <Section
    eyebrow="How to choose in 30 seconds"
    title="All three partner platforms share the same AMD Strix Halo / AI Max+ 395 architecture"
    subtitle="The difference is not performance — it is optimization focus."
    align="left"
  >
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="card border-neon-purple/30 bg-dark-900/50">
        <div class="text-sm font-semibold text-neon-purple">BOSGAME</div>
        <div class="mt-2 text-lg font-bold text-white">Optimized for general AI workloads</div>
        <p class="mt-1 text-sm text-slate-400">We evaluate balanced compute and memory scenarios.</p>
      </div>
      <div class="card border-neon-cyan/30 bg-dark-900/50">
        <div class="text-sm font-semibold text-neon-cyan">PELAND</div>
        <div class="mt-2 text-lg font-bold text-white">Optimized for memory-intensive inference</div>
        <p class="mt-1 text-sm text-slate-400">We evaluate long-context AI workloads.</p>
      </div>
      <div class="card border-neon-orange/30 bg-dark-900/50">
        <div class="text-sm font-semibold text-neon-orange">BITPC</div>
        <div class="mt-2 text-lg font-bold text-white">Optimized for compact deployment</div>
        <p class="mt-1 text-sm text-slate-400">We evaluate small-scale AI systems.</p>
      </div>
    </div>
    <div class="mt-6 card border-neon-purple/30 bg-dark-900/50">
      <p class="text-sm font-medium text-neon-purple">What this means for you:</p>
      <p class="mt-2 text-sm text-slate-400">
        You can confidently choose based on your specific needs without worrying about performance differences. All three options deliver the same core AI capabilities — the variation is in how they are optimized for different use cases.
      </p>
    </div>
  </Section>

  <!-- Brand options -->
  <Section
    eyebrow="Partner brand options"
    title="Choose a brand option"
    subtitle="Not sure which option fits? Use the side-by-side comparison or the recommendation engine."
  >
    <div class="grid gap-8 lg:grid-cols-3">
      {brands.map((brand) => {
        const brandCardClass = brand.name === 'BOSGAME' ? 'card-neon' : brand.name === 'PELAND' ? 'card-cyan' : 'card-orange';
        const brandBadgeClass = brand.name === 'BOSGAME' ? 'badge' : brand.name === 'PELAND' ? 'badge-cyan' : 'badge-orange';
        const brandTextClass = brand.name === 'BOSGAME' ? 'text-neon-purple' : brand.name === 'PELAND' ? 'text-neon-cyan' : 'text-neon-orange';
        const getTagline = () => {
          switch(brand.name) {
            case 'BOSGAME': return 'Best for developers and general AI workflows.';
            case 'PELAND': return 'Best for sustained LLM / RAG workloads and memory-heavy tasks.';
            case 'BITPC': return 'Best for compact deployment and small team setups.';
            default: return '';
          }
        };
        return (
          <a href={`/workstations/${brand.slug}`} onclick="trackEvent('workstation_click', { brand: `${brand.name}` })" class={`group relative flex flex-col overflow-hidden rounded-3xl transition-all duration-300 hover:-translate-y-2 ${brandCardClass} shadow-xl shadow-black/20`}>
            <div class="relative overflow-hidden">
              <ProductMock variant="card" brand={brand.name} />
              <div class="absolute top-4 left-4">
                <span class={brandBadgeClass}>{brand.region}</span>
              </div>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h3 class="text-2xl font-bold text-white">{brand.name}</h3>
              <p class="mt-1 text-sm font-medium text-slate-300">{getTagline()}</p>
              <p class="mt-3 text-slate-300">{brand.summary}</p>
              <div class="mt-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Highlights</div>
                <ul class="mt-2 space-y-1.5 text-sm text-slate-400">
                  {brand.highlights.map((h) => <li>• {h}</li>)}
                </ul>
              </div>
              <p class="mt-4 text-xs italic text-slate-500">{brand.note}</p>
              <div class={`mt-6 flex items-center text-sm font-medium ${brandTextClass}`}>
                View {brand.name} details
                <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href="/workstations/compare" class="btn-secondary">Compare all three options</a>
      <a href="/recommendation-engine" class="btn border border-slate-700 bg-transparent text-slate-200 hover:border-neon-purple/50 hover:bg-dark-800 hover:text-white">Recommendation engine</a>
    </div>
  </Section>

  <!-- Common confusion block -->
  <Section
    eyebrow="Common confusion"
    title="All three options run the same platform"
    align="left"
  >
    <div class="card border-neon-purple/30 bg-dark-900/50">
      <p class="text-slate-300">
        All three partner platforms share the same AMD Strix Halo / AI Max+ 395 architecture. 
        Differences are in thermal design, chassis, and workload tuning — not raw performance.
      </p>
      <div class="mt-4 p-4 rounded-lg bg-dark-800/50 border border-white/10">
        <p class="text-sm text-neon-yellow">
          <strong>Pro tip:</strong> If you are unsure, start from Use Cases instead of choosing a brand. 
          This will help you match your workload to the right hardware.
        </p>
      </div>
    </div>
  </Section>

  <!-- Important note -->
  <Section
    eyebrow="Important note"
    title="What Syvidea is not"
    align="left"
  >
    <div class="card border-neon-orange/30 bg-dark-900/60">
      <div class="flex items-start gap-4">
        <div class="shrink-0">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-neon-orange to-neon-yellow text-dark-999 font-bold shadow-lg shadow-neon-orange/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
          </div>
        </div>
        <p class="text-slate-300 leading-relaxed">
          Syvidea is not the manufacturer of these workstations. They are produced by our hardware partners
          (BOSGAME, PELAND, BITPC). Syvidea acts as a sourcing and advisory layer, helping you choose the right
          option, get a quote, and coordinate delivery. The three brand options share the same core AMD Strix
          Halo / AI Max+ 395 platform, but they are not identical units.
        </p>
      </div>
    </div>
  </Section>
</PageLayout>
