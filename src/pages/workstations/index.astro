---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/Section.astro';
import PlatformNotice from '../../components/PlatformNotice.astro';
import { sharedPlatform } from '../../data/platform';
---
<PageLayout
  title="Workstations — Syvidea"
  description="Curated S1 Series workstations on the AMD Strix Halo / AI Max+ 395 platform. Compare S1 Base, S1 Pro, and S1 Max configurations."
>
  <PlatformNotice />
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-20"></div>
    <div class="glow-bg top-10 left-1/3 h-96 w-96 bg-neon-purple/20 animate-glow-pulse"></div>
    <div class="glow-bg bottom-10 right-1/3 h-80 w-80 bg-neon-cyan/15 animate-glow-pulse" style="animation-delay:-2s;"></div>

    <div class="container-page relative">
      <div class="mx-auto max-w-3xl text-center">
        <div class="mb-5 flex justify-center">
          <span class="badge">Workstations</span>
        </div>
        <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl gradient-text">
          Curated partner workstation options
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 text-balance">
          All options share the same AMD Strix Halo / AI Max+ 395 platform. Choose the S1 model that best matches your chassis, I/O, and supply preferences.
        </p>
      </div>
    </div>
  </section>

  <!-- Shared platform strip -->
  <section class="border-y border-slate-800 bg-dark-900/30">
    <div class="container-page py-10">
      <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div>
          <div class="text-xs font-semibold uppercase tracking-wider text-neon-purple">Shared platform</div>
          <h2 class="mt-1 text-2xl font-bold text-white">{sharedPlatform.name}</h2>
          <p class="mt-1 text-slate-400 max-w-2xl">{sharedPlatform.tagline}</p>
        </div>
        <a href="/workstations/platform" class="btn-secondary shrink-0">
          See full platform spec
          <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How to choose -->
  <Section
    eyebrow="How to choose in 30 seconds"
    title="All three S1 Series models share the same AMD Strix Halo / AI Max+ 395 architecture"
    subtitle="The difference is not performance — it is optimization focus."
    align="left"
  >
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="card border-neon-purple/30 bg-dark-900/50">
        <div class="text-sm font-semibold text-neon-purple">S1 Base</div>
        <div class="mt-2 text-lg font-bold text-white">Optimized for general AI workloads</div>
        <p class="mt-1 text-sm text-slate-400">We evaluate balanced compute and memory scenarios.</p>
      </div>
      <div class="card border-neon-cyan/30 bg-dark-900/50">
        <div class="text-sm font-semibold text-neon-cyan">S1 Pro</div>
        <div class="mt-2 text-lg font-bold text-white">Optimized for memory-intensive inference</div>
        <p class="mt-1 text-sm text-slate-400">We evaluate long-context AI workloads.</p>
      </div>
      <div class="card border-neon-orange/30 bg-dark-900/50">
        <div class="text-sm font-semibold text-neon-orange">S1 Max</div>
        <div class="mt-2 text-lg font-bold text-white">Optimized for compact deployment</div>
        <p class="mt-1 text-sm text-slate-400">We evaluate small-scale AI systems.</p>
      </div>
    </div>
    <div class="mt-6 card border-neon-purple/30 bg-dark-900/50">
      <p class="text-sm font-medium text-neon-purple">What this means for you:</p>
      <p class="mt-2 text-sm text-slate-400">
        You can confidently choose based on your specific needs without worrying about performance differences. All three options deliver the same core AI capabilities — the variation is in how they are optimized for different use cases.
      </p>
    </div>
  </Section>

  <!-- S1 Series overview -->
  <Section
    eyebrow="S1 Series"
    title="Syvidea S1 Series Workstations"
    subtitle="All models feature the same AMD Strix Halo / AI Max+ 395 platform with 128GB unified memory and 2TB NVMe SSD. Syvidea evaluates your AI workload and recommends the optimal configuration."
  >
    <div class="card border border-neon-purple/30 bg-dark-900/60 rounded-3xl p-8">
      <div class="grid gap-6 lg:grid-cols-3">
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-neon-purple/20 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-neon-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <line x1="9" y1="9" x2="15" y2="9" />
              <line x1="9" y1="15" x2="15" y2="15" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">128GB Unified Memory</h3>
          <p class="text-sm text-slate-400">Enables local 70B model inference</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-neon-cyan/20 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-neon-cyan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2" />
              <line x1="12" y1="22" x2="12" y2="15.5" />
              <line x1="22" y1="8.5" x2="12" y2="15.5" />
              <line x1="2" y1="8.5" x2="12" y2="15.5" />
              <line x1="2" y1="15.5" x2="12" y2="15.5" />
              <line x1="22" y1="15.5" x2="12" y2="15.5" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">50 TOPS NPU</h3>
          <p class="text-sm text-slate-400">Accelerated AI inference</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-neon-orange/20 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">2TB NVMe SSD</h3>
          <p class="text-sm text-slate-400">Fast storage for model loading</p>
        </div>
      </div>
      <div class="mt-8 text-center">
        <p class="text-sm text-slate-400 mb-4">Syvidea evaluates your workload and matches you with the right configuration for your specific use case.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/start-here" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-neon-purple to-neon-cyan text-white font-semibold rounded-xl hover:opacity-90 transition-opacity">
            Find Your Configuration
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
          <a href="/recommendation-engine" class="btn border border-slate-700 bg-transparent text-slate-200 hover:border-neon-purple/50 hover:bg-dark-800 hover:text-white">Recommendation engine</a>
        </div>
      </div>
    </div>
  </Section>

  <!-- Common confusion block -->
  <Section
    eyebrow="Important note"
    title="What Syvidea does"
    align="left"
  >
    <div class="card border-neon-orange/30 bg-dark-900/60">
      <div class="flex items-start gap-4">
        <div class="shrink-0">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-neon-orange to-neon-yellow text-dark-999 font-bold shadow-lg shadow-neon-orange/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
          </div>
        </div>
        <p class="text-slate-300 leading-relaxed">
          Syvidea curates and configures workstations exclusively for local AI applications. We evaluate your workload and recommend the optimal configuration built on the AMD Strix Halo / AI Max+ 395 platform with 128GB unified memory and 2TB NVMe SSD.
        </p>
      </div>
    </div>
  </Section>
</PageLayout>
