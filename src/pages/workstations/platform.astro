---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/Section.astro';
import ProductMock from '../../components/ProductMock.astro';
import { sharedPlatform } from '../../data/platform';
import { brands } from '../../data/brands';

const specGroups = [
  {
    title: 'Processor & AI',
    items: [
      { label: sharedPlatform.processor.name, detail: `${sharedPlatform.processor.architecture} • ${sharedPlatform.processor.cores} • ${sharedPlatform.processor.boost}` },
      { label: sharedPlatform.processor.npu, detail: sharedPlatform.processor.aiPerformance },
    ],
  },
  {
    title: 'Memory & Storage',
    items: [
      { label: sharedPlatform.memory.capacity, detail: `${sharedPlatform.memory.type} • ${sharedPlatform.memory.bandwidth}` },
      { label: sharedPlatform.storage.capacity, detail: sharedPlatform.storage.slots },
    ],
  },
  {
    title: 'Graphics & Display',
    items: [
      { label: sharedPlatform.graphics.integrated, detail: sharedPlatform.graphics.architecture },
      { label: sharedPlatform.connectivity.usb4, detail: sharedPlatform.connectivity.networking },
    ],
  },
  {
    title: 'Form Factor & Cooling',
    items: [
      { label: sharedPlatform.formFactor.class, detail: sharedPlatform.formFactor.benefit },
      { label: sharedPlatform.powerAndCooling.cooling, detail: sharedPlatform.powerAndCooling.power },
    ],
  },
];
---
<PageLayout
  title="AMD Strix Halo Local AI Workstation Platform — Syvidea"
  description="Shared platform specification for Syvidea's curated partner workstation options. AMD Ryzen AI Max+ 395, 128GB LPDDR5X unified memory, 2TB SSD, dual PCIe 4.0 SSD."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-20"></div>
    <div class="glow-bg top-10 left-1/3 h-96 w-96 bg-neon-purple/20 animate-glow-pulse"></div>
    <div class="glow-bg bottom-10 right-1/3 h-80 w-80 bg-neon-cyan/15 animate-glow-pulse" style="animation-delay:-2s;"></div>

    <div class="container-page relative">
      <div class="mx-auto max-w-3xl text-center">
        <div class="mb-5 flex justify-center">
          <span class="badge">Shared platform specification</span>
        </div>
        <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl gradient-text">
          {sharedPlatform.name}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 text-balance">
          {sharedPlatform.tagline}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/request-quote" class="text-neon-purple hover:underline">Request a configuration quote →</a>
          <a href="/workstations/compare" class="text-slate-400 hover:text-white">Compare brand options →</a>
        </div>
      </div>

      <div class="relative mx-auto mt-16 max-w-4xl">
        <div class="absolute -inset-12 rounded-[3rem] bg-gradient-to-br from-neon-purple/20 via-neon-cyan/15 to-neon-orange/10 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-3xl border border-slate-800/60 bg-dark-900/50 shadow-2xl shadow-black/40 backdrop-blur-xl">
          <ProductMock variant="detail" brand="default" />
        </div>
      </div>
    </div>
  </section>

  <!-- Key stats strip -->
  <section class="border-y border-slate-800 bg-dark-900/30">
    <div class="container-page py-10">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        <div>
          <div class="text-3xl font-bold gradient-text-purple">{sharedPlatform.processor.cores}</div>
          <div class="mt-1 text-sm text-slate-400">{sharedPlatform.processor.architecture} cores</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text-cyan">128<span class="text-lg">GB</span></div>
          <div class="mt-1 text-sm text-slate-400">{sharedPlatform.memory.type}</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text-orange">2<span class="text-lg">TB</span></div>
          <div class="mt-1 text-sm text-slate-400">PCIe 4.0 SSD</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text">3</div>
          <div class="mt-1 text-sm text-slate-400">Partner brands</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Shared platform section -->
  <Section
    eyebrow="Why a shared platform page"
    title="Because the three partner brands share the same core spec"
    subtitle="This page describes the shared platform that all three partner workstation options are built on. For brand-specific differences (chassis, I/O details, dimensions, wireless, thermals, BIOS, packaging, warranty, supply), see each brand's detail page or the comparison page."
    align="left"
  >
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brands.map((b) => {
        const brandColor = b.name === 'BOSGAME' ? 'text-neon-purple' : b.name === 'PELAND' ? 'text-neon-cyan' : 'text-neon-orange';
        return (
          <a href={`/workstations/${b.slug}`} class="card group flex flex-col">
            <h3 class="text-lg font-bold text-slate-200 group-hover:text-white transition-colors">{b.name}</h3>
            <p class="mt-1 text-sm text-slate-400">{b.positioning}</p>
            <p class="mt-3 text-sm text-slate-300 flex-1">{b.note}</p>
            <div class={`mt-5 text-sm font-medium ${brandColor}`}>View {b.name} details →</div>
          </a>
        );
      })}
    </div>
  </Section>

  <!-- Specification cards -->
  <Section
    eyebrow="Specification"
    title="Shared platform spec"
    subtitle="Identical across BOSGAME, PELAND, and BITPC configurations."
    align="left"
  >
    <div class="grid gap-6 lg:grid-cols-2">
      {specGroups.map((group) => (
        <div class="spec-card">
          <h3 class="text-lg font-bold gradient-text">{group.title}</h3>
          <div class="mt-4 space-y-4">
            {group.items.map((item) => (
              <div class="flex items-start justify-between gap-4 border-t border-slate-800/60 pt-4 first:border-0 first:pt-0">
                <div class="font-semibold text-slate-200">{item.label}</div>
                <div class="text-right text-sm text-slate-400">{item.detail}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Why this platform -->
  <Section
    eyebrow="Why this platform"
    title="Designed for local LLM, RAG, agents, and multimodal AI"
  >
    <div class="grid gap-6 md:grid-cols-2">
      <div class="card">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-neon-purple to-neon-pink text-white shadow-lg shadow-neon-purple/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <line x1="8" y1="21" x2="16" y2="21" />
            <line x1="12" y1="17" x2="12" y2="21" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-200">Large unified memory pool</h3>
        <p class="mt-2 text-slate-400">
          128GB LPDDR5X with a 256-bit memory interface gives local AI workflows the headroom to run
          70B-class quantized models, private RAG contexts, and multi-tool agent stacks on a single machine.
        </p>
      </div>
      <div class="card">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-neon-cyan to-neon-blue text-white shadow-lg shadow-neon-cyan/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="12" cy="5" rx="9" ry="3" />
            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-200">Modern I/O and storage</h3>
        <p class="mt-2 text-slate-400">
          Dual M.2 PCIe 4.0 SSD slots support fast local model storage and dataset expansion. USB4 / Thunderbolt-class
          high-speed ports enable modern peripherals and external GPU or storage expansion.
        </p>
      </div>
      <div class="card">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-neon-orange to-neon-yellow text-white shadow-lg shadow-neon-orange/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
            <line x1="12" y1="22.08" x2="12" y2="12" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-200">Compact form factor</h3>
        <p class="mt-2 text-slate-400">
          A compact footprint makes the platform suitable for desk-side deployment, homelab racks, and small-team
          shared environments where space and noise matter.
        </p>
      </div>
      <div class="card">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-neon-green to-neon-cyan text-white shadow-lg shadow-neon-green/30">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 2 7 12 12 22 7 12 2" />
            <polyline points="2 17 12 22 22 17" />
            <polyline points="2 12 12 17 22 12" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-200">NPU + integrated GPU</h3>
        <p class="mt-2 text-slate-400">
          AMD XDNA 2 NPU and Radeon 8060S integrated graphics provide on-device AI acceleration suitable for
          inference, multimodal workflows, and supported creative tooling.
        </p>
      </div>
    </div>
  </Section>

  <!-- Trade-offs -->
  <Section
    eyebrow="What this platform is not for"
    title="Honest trade-offs"
    align="left"
  >
    <div class="card border-neon-orange/30 bg-dark-900/60">
      <div class="flex items-start gap-4">
        <div class="shrink-0">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-neon-orange to-neon-yellow text-dark-999 font-bold shadow-lg shadow-neon-orange/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
          </div>
        </div>
        <ul class="space-y-2 text-slate-300">
          <li>• Not the fastest CUDA image-generation box. If your only goal is maximum Flux or SDXL speed with CUDA / TensorRT, an NVIDIA RTX 5090 workstation is a better fit.</li>
          <li>• Not for large-scale model training.</li>
          <li>• Not positioned as a cheap office Mini PC.</li>
          <li>• Not for users who want direct full-payment online checkout without communication.</li>
        </ul>
      </div>
    </div>
  </Section>
</PageLayout>
