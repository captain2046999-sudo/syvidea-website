---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/Section.astro';
import ProductMock from '../../components/ProductMock.astro';
import { brands } from '../../data/brands';
import { sharedPlatform } from '../../data/platform';

export function getStaticPaths() {
  return brands.map((brand) => ({
    params: { brand: brand.slug },
    props: { brand },
  }));
}

const { brand } = Astro.props;

const brandTheme = brand.name.includes('S1 Base')
  ? { primary: 'neon-purple', secondary: 'neon-pink', gradient: 'from-neon-purple via-neon-pink to-neon-cyan', glow: 'shadow-neon-purple/30' }
  : brand.name.includes('S1 Pro')
  ? { primary: 'neon-cyan', secondary: 'neon-blue', gradient: 'from-neon-cyan via-neon-blue to-neon-green', glow: 'shadow-neon-cyan/30' }
  : { primary: 'neon-orange', secondary: 'neon-yellow', gradient: 'from-neon-orange via-neon-yellow to-neon-pink', glow: 'shadow-neon-orange/30' };


---
<PageLayout
  title={`${brand.name} — Local AI Workstation Option | Syvidea`}
  description={`${brand.summary} Curated partner option on the AMD Strix Halo / AI Max+ 395 platform.`}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-20"></div>
    <div class="glow-bg top-10 left-1/4 h-96 w-96" style={`background:var(--color-${brandTheme.primary});opacity:0.20;animation:glowPulse 2s ease-in-out infinite;`}></div>
    <div class="glow-bg top-20 right-1/4 h-80 w-80" style={`background:var(--color-${brandTheme.secondary});opacity:0.15;animation:glowPulse 2s ease-in-out infinite;animation-delay:-2s;`}></div>

    <div class="container-page relative">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <div class="mb-5 inline-flex">
            <span class="badge">S1 Series model</span>
          </div>
          <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl" style={`background:linear-gradient(90deg,var(--color-${brandTheme.primary}),var(--color-${brandTheme.secondary}));-webkit-background-clip:text;background-clip:text;color:transparent;`}>
            {brand.name}
          </h1>
          <p class="mt-6 text-lg text-slate-400 text-balance max-w-xl">
            {brand.summary}
          </p>
          <div class="mt-4">
            <span class={`inline-flex items-center rounded-full border border-${brandTheme.primary}/30 bg-${brandTheme.primary}/10 px-3 py-1 text-xs font-medium text-${brandTheme.primary}`}>{brand.positioning}</span>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/request-quote" class="text-neon-purple hover:underline">Request a configuration quote →</a>
            <a href={`/workstations/${sharedPlatform.slug}`} class="text-slate-400 hover:text-white">See shared platform spec →</a>
          </div>

          <div class="mt-10 grid grid-cols-3 gap-4">
            <div>
              <div class="text-2xl font-bold gradient-text-cyan">128GB</div>
              <div class="text-xs text-slate-400">Unified memory</div>
            </div>
            <div>
              <div class="text-2xl font-bold gradient-text-purple">2TB</div>
              <div class="text-xs text-slate-400">PCIe 4.0 SSD</div>
            </div>
            <div>
              <div class="text-2xl font-bold gradient-text-orange">AI Max+</div>
              <div class="text-xs text-slate-400">395 processor</div>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-8 rounded-[3rem]" style={`background:linear-gradient(135deg,var(--color-${brandTheme.primary})20,var(--color-${brandTheme.secondary})15,transparent);filter:blur(3rem);`}></div>
          <div class="relative overflow-hidden rounded-3xl border border-slate-800/60 bg-dark-900/50 shadow-2xl shadow-black/40 backdrop-blur-xl">
            <ProductMock variant="hero" brand={brand.name} />
          </div>
        </div>
      </div>
    </div>
  </section>

  {brand.images && (
    <section class="relative py-16 sm:py-20">
      <div class="container-page">
        <div class="text-center mb-12">
          <div class="inline-flex items-center rounded-full border border-slate-700 bg-dark-900/50 px-4 py-1.5 text-xs font-medium text-slate-400">
            Product views
          </div>
          <h2 class="mt-4 text-2xl font-bold text-white sm:text-3xl">View from different angles</h2>
        </div>
        
        <div class="grid gap-6 sm:grid-cols-3">
          {brand.images.front && (
            <div class="group relative overflow-hidden rounded-2xl border border-slate-800 bg-dark-900/60 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
              <div class="aspect-square overflow-hidden">
                <img
                  src={brand.images.front}
                  alt={`${brand.name} front view`}
                  loading="lazy"
                  class="h-full w-full object-contain p-6 transition-transform duration-500 group-hover:scale-105"
                />
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-dark-999/90 to-transparent p-4">
                <span class={`text-sm font-medium ${brandTheme.primary === 'neon-purple' ? 'text-neon-purple' : brandTheme.primary === 'neon-cyan' ? 'text-neon-cyan' : 'text-neon-orange'}`}>Front view</span>
              </div>
            </div>
          )}
          
          {brand.images.side && (
            <div class="group relative overflow-hidden rounded-2xl border border-slate-800 bg-dark-900/60 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
              <div class="aspect-square overflow-hidden">
                <img
                  src={brand.images.side}
                  alt={`${brand.name} side view`}
                  loading="lazy"
                  class="h-full w-full object-contain p-6 transition-transform duration-500 group-hover:scale-105"
                />
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-dark-999/90 to-transparent p-4">
                <span class={`text-sm font-medium ${brandTheme.primary === 'neon-purple' ? 'text-neon-purple' : brandTheme.primary === 'neon-cyan' ? 'text-neon-cyan' : 'text-neon-orange'}`}>Side view</span>
              </div>
            </div>
          )}
          
          {brand.images.ports && (
            <div class="group relative overflow-hidden rounded-2xl border border-slate-800 bg-dark-900/60 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
              <div class="aspect-square overflow-hidden">
                <img
                  src={brand.images.ports}
                  alt={`${brand.name} ports view`}
                  loading="lazy"
                  class="h-full w-full object-contain p-6 transition-transform duration-500 group-hover:scale-105"
                />
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-dark-999/90 to-transparent p-4">
                <span class={`text-sm font-medium ${brandTheme.primary === 'neon-purple' ? 'text-neon-purple' : brandTheme.primary === 'neon-cyan' ? 'text-neon-cyan' : 'text-neon-orange'}`}>Ports view</span>
              </div>
            </div>
          )}
        </div>

        <div class="mt-10 text-center">
          <p class="text-slate-400 mb-4">Need more photos or detailed configuration?</p>
          <a href="/request-quote" class={`inline-flex items-center gap-2 text-sm font-medium ${brandTheme.primary === 'neon-purple' ? 'text-neon-purple' : brandTheme.primary === 'neon-cyan' ? 'text-neon-cyan' : 'text-neon-orange'} hover:underline`}>
            Request a quote for the full gallery and specs →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Positioning -->
  <Section
    eyebrow="Positioning"
    title={`${brand.name} on the shared platform`}
    align="left"
  >
    <div class={`card border-${brandTheme.primary}/30 bg-dark-900/60 shadow-lg ${brandTheme.glow}`}>
      <h3 class="text-xl font-bold text-white">{brand.positioning}</h3>
      <p class="mt-3 text-slate-300 leading-relaxed">
        {brand.name} workstations are built on the shared AMD Strix Halo / AI Max+ 395 platform. The core
        processor, memory, storage, and I/O capabilities are the same as other partner options. The differences
        live in chassis, port layout, dimensions, wireless modules, thermals, BIOS tuning, packaging, warranty,
        and supply batches.
      </p>
    </div>
  </Section>

  <!-- Highlights -->
  <Section
    eyebrow="Highlights"
    title={`${brand.name} configuration highlights`}
  >
    <div class="grid gap-4 sm:grid-cols-2">
      {brand.highlights.map((h) => (
        <div class="spec-card flex items-start gap-4">
          <span class={`mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-${brandTheme.primary} to-${brandTheme.secondary} text-white shadow-lg ${brandTheme.glow}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          <span class="text-slate-300 font-medium">{h}</span>
        </div>
      ))}
    </div>
  </Section>

  <!-- Shared spec -->
  <Section
    eyebrow="Shared spec"
    title="The platform behind the option"
    align="left"
  >
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="spec-card">
        <div class={`text-xs font-semibold uppercase tracking-wider text-${brandTheme.primary}`}>Processor</div>
        <div class="mt-3 text-xl font-bold gradient-text-purple">{sharedPlatform.processor.name}</div>
        <p class="mt-2 text-sm text-slate-400">{sharedPlatform.processor.cores}</p>
      </div>
      <div class="spec-card">
        <div class={`text-xs font-semibold uppercase tracking-wider text-${brandTheme.primary}`}>Memory</div>
        <div class="mt-3 text-xl font-bold gradient-text-cyan">{sharedPlatform.memory.capacity}</div>
        <p class="mt-2 text-sm text-slate-400">{sharedPlatform.memory.bandwidth}</p>
      </div>
      <div class="spec-card">
        <div class={`text-xs font-semibold uppercase tracking-wider text-${brandTheme.primary}`}>Storage</div>
        <div class="mt-3 text-xl font-bold gradient-text-orange">{sharedPlatform.storage.capacity}</div>
        <p class="mt-2 text-sm text-slate-400">{sharedPlatform.storage.slots}</p>
      </div>
      <div class="spec-card">
        <div class={`text-xs font-semibold uppercase tracking-wider text-${brandTheme.primary}`}>Form factor</div>
        <div class="mt-3 text-xl font-bold gradient-text">{sharedPlatform.formFactor.class}</div>
        <p class="mt-2 text-sm text-slate-400">Compact workstation</p>
      </div>
    </div>
    <div class="mt-8 text-sm text-slate-400">
      See the full shared platform spec on the
      <a href={`/workstations/${sharedPlatform.slug}`} class={`text-${brandTheme.primary} underline`}>shared platform page</a>.
    </div>
  </Section>

  <!-- Technical Specifications -->
  <Section
    eyebrow="Technical"
    title="Detailed specifications"
    align="left"
  >
    <div class={`card border-${brandTheme.primary}/30 bg-dark-900/60`}>
      <div class="overflow-hidden rounded-xl border border-slate-800/60">
        <div class="grid divide-y divide-slate-800">
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Processor</div>
            <div class="text-sm text-white">{sharedPlatform.processor.name}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Architecture</div>
            <div class="text-sm text-white">{sharedPlatform.processor.architecture}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Cores / Threads</div>
            <div class="text-sm text-white">{sharedPlatform.processor.cores}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Max Boost</div>
            <div class="text-sm text-white">{sharedPlatform.processor.boost}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">AI Performance</div>
            <div class="text-sm text-white">{sharedPlatform.processor.aiPerformance}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">NPU</div>
            <div class="text-sm text-white">{sharedPlatform.processor.npu}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Memory Type</div>
            <div class="text-sm text-white">{sharedPlatform.memory.type}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Memory Capacity</div>
            <div class="text-sm text-white">{sharedPlatform.memory.capacity}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Memory Interface</div>
            <div class="text-sm text-white">{sharedPlatform.memory.bandwidth}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Storage Slots</div>
            <div class="text-sm text-white">{sharedPlatform.storage.slots}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Typical Storage</div>
            <div class="text-sm text-white">{sharedPlatform.storage.capacity}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Graphics</div>
            <div class="text-sm text-white">{sharedPlatform.graphics.integrated}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Graphics Architecture</div>
            <div class="text-sm text-white">{sharedPlatform.graphics.architecture}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">High-Speed I/O</div>
            <div class="text-sm text-white">{sharedPlatform.connectivity.usb4}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Networking</div>
            <div class="text-sm text-white">{sharedPlatform.connectivity.networking}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Wireless</div>
            <div class="text-sm text-white">{sharedPlatform.connectivity.wireless}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4 bg-dark-800/30">
            <div class="text-sm font-medium text-slate-400">Form Factor</div>
            <div class="text-sm text-white">{sharedPlatform.formFactor.class}</div>
          </div>
          <div class="grid grid-cols-2 gap-4 px-6 py-4">
            <div class="text-sm font-medium text-slate-400">Cooling</div>
            <div class="text-sm text-white">{sharedPlatform.powerAndCooling.cooling}</div>
          </div>
        </div>
      </div>
      <div class="mt-4 text-center">
        <p class="text-sm text-slate-400">Brand-specific dimensions, exact port layout, and power supply specs vary. </p>
        <a href="/request-quote" class={`inline-flex items-center gap-2 mt-2 text-sm font-medium ${brandTheme.primary === 'neon-purple' ? 'text-neon-purple' : brandTheme.primary === 'neon-cyan' ? 'text-neon-cyan' : 'text-neon-orange'} hover:underline`}>
          Request a quote for complete brand-specific specifications →
        </a>
      </div>
    </div>
  </Section>

  <!-- Brand-specific note -->
  <Section
    eyebrow="Note"
    title="Brand-specific differences"
    align="left"
  >
    <div class={`card border-${brandTheme.primary}/30 bg-dark-900/60`}>
      <div class="flex items-start gap-4">
        <div class="shrink-0">
          <div class={`inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-${brandTheme.primary} to-${brandTheme.secondary} text-white shadow-lg ${brandTheme.glow}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
          </div>
        </div>
        <p class="text-slate-300 leading-relaxed">
          {brand.note} The exact configuration, BIOS, thermals, packaging, accessories, warranty terms, and
          supply batches vary by partner. Submit a quote request and we will share the latest configuration
          details, photos, and price quote for {brand.name} for your destination.
        </p>
      </div>
    </div>
  </Section>

  <!-- Other options -->
  <Section
    eyebrow="Not a fit?"
    title="See other S1 Series models"
  >
    <div class="grid gap-8 sm:grid-cols-2">
      {brands.filter((b) => b.slug !== brand.slug).map((b) => {
        const otherBrandTheme = b.name.includes('S1 Base') ? 'card-neon' : b.name.includes('S1 Pro') ? 'card-cyan' : 'card-orange';
        const otherBadgeClass = b.name.includes('S1 Base') ? 'badge' : b.name.includes('S1 Pro') ? 'badge-cyan' : 'badge-orange';
        const otherTextClass = b.name.includes('S1 Base') ? 'text-neon-purple' : b.name.includes('S1 Pro') ? 'text-neon-cyan' : 'text-neon-orange';
        return (
          <a href={`/workstations/${b.slug}`} class={`group relative flex flex-col overflow-hidden rounded-3xl transition-all duration-300 hover:-translate-y-2 ${otherBrandTheme} shadow-xl shadow-black/20`}>
            <div class="relative overflow-hidden">
              <ProductMock variant="card" brand={b.name} />
              {b.region && (
                <div class="absolute top-4 left-4">
                  <span class={otherBadgeClass}>{b.region}</span>
                </div>
              )}
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h3 class="text-xl font-bold text-white">{b.name}</h3>
              <p class="mt-2 text-slate-400 flex-1">{b.summary}</p>
              <div class={`mt-5 text-sm font-medium ${otherTextClass}`}>View details →</div>
            </div>
          </a>
        );
      })}
    </div>
  </Section>

</PageLayout>
