---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

---
<PageLayout
  title="About — Syvidea"
  description="About Syvidea: a sourcing and advisory service for AMD Strix Halo / AI Max+ 395 local AI workstations."
>
  <Hero
    eyebrow="About"
    title="Your local AI workstation sourcing partner"
    subtitle="Syvidea helps developers, creators, and small teams choose, compare, and source local AI workstations built on the AMD Strix Halo / AI Max+ 395 platform."
  />

  <Section
    eyebrow="What we do"
    title="Six things Syvidea does"
    align="left"
  >
    <div class="grid gap-6 sm:grid-cols-2">
      {[
        { title: 'Multi-brand selection advisor', desc: 'Help you compare BOSGAME, PELAND, and BITPC options built on the same shared platform.' },
        { title: 'Local AI workflow explainer', desc: 'Translate local AI workflows (LLM, RAG, agents, multimodal) into the right hardware and configuration choices.' },
        { title: 'Quote and pricing service', desc: 'Provide a written quote with configuration, price, shipping, and any duties for your destination.' },
        { title: 'Supply and delivery coordination', desc: 'Coordinate the supply batch, shipping, and any cross-border handling.' },
        { title: 'Setup and resources', desc: 'Share setup guides, model compatibility notes, troubleshooting, and driver entry points.' },
        { title: 'Market validation for future products', desc: 'Help validate whether a future Syvidea Edition or co-branded product makes sense for the market.' },
      ].map((item) => (
        <div class="card">
          <h3 class="text-lg font-semibold">{item.title}</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section
    eyebrow="Our approach"
    title="How we differ from other channels"
    align="left"
  >
    <div class="card border-neon-purple/30 dark:border-neon-purple/50 bg-dark-900/50">
      <ul class="space-y-3 text-slate-700 dark:text-slate-300">
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-2 w-2 rounded-full bg-neon-purple"></span>
          <span><strong class="text-slate-200">Partner-sourced hardware:</strong> We work directly with trusted manufacturers (BOSGAME, PELAND, BITPC) to ensure configuration consistency across workloads.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-2 w-2 rounded-full bg-neon-cyan"></span>
          <span><strong class="text-slate-200">AI-focused, not generic:</strong> Every recommendation is validated against real local AI workloads, not just hardware specs.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-2 w-2 rounded-full bg-neon-orange"></span>
          <span><strong class="text-slate-200">Quote-based ordering:</strong> Each configuration is reviewed manually before quoting, ensuring compatibility and performance fit.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-2 w-2 rounded-full bg-neon-green"></span>
          <span><strong class="text-slate-200">Transparent pricing:</strong> Full cost breakdown including shipping, duties, and lead times in every quote.</span>
        </li>
      </ul>
    </div>
  </Section>

  <Section
    eyebrow="Services"
    title="How we work"
    align="left"
  >
    <div class="card">
      <p class="text-slate-700 dark:text-slate-300 leading-relaxed">
        Syvidea operates as a sourcing and advisory service. Orders are quote-based
        with personal confirmation and a payment link after the quote is approved.
      </p>
    </div>
  </Section>
</PageLayout>
