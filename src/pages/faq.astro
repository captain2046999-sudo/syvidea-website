---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { faqs } from '../data/faqs';
---
<PageLayout
  title="FAQ — Syvidea"
  description="Common questions about the AMD Strix Halo / AI Max+ 395 platform, S1 Series models, sourcing process, and what this product is not for."
>
  <Hero
    eyebrow="FAQ"
    title="Questions founders and AI builders ask first"
    subtitle="If you have a question that is not covered here, send it via the contact form. We will reply and may add it to this page."
  />

  <Section
    eyebrow="Browse by topic"
    title="Frequently asked questions"
    align="left"
  >
    <div class="space-y-10">
      {faqs.map((group) => (
        <div>
          <h3 class="text-xl font-bold mb-4 text-white">{group.category}</h3>
          <div class="space-y-3">
            {group.items.map((item) => (
              <details class="group rounded-2xl border border-slate-800 bg-dark-900/60 p-5 backdrop-blur-sm transition-all duration-300 hover:border-neon-purple/30">
                <summary class="flex cursor-pointer items-start justify-between gap-4 font-medium text-white">
                  <span>{item.q}</span>
                  <span class="ml-auto inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-slate-700 text-slate-400 transition-transform group-open:rotate-45 group-open:border-neon-purple group-open:text-neon-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                  </span>
                </summary>
                <div class="mt-3 text-slate-400 leading-relaxed">
                  {item.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>
</PageLayout>
