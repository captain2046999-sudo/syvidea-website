---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import CTA from '../components/CTA.astro';
import { faqs } from '../data/faqs';
---
<PageLayout
  title="FAQ — Syvidea"
  description="Common questions about the AMD Strix Halo / AI Max+ 395 platform, partner brands (Bosgame, PELAND, bitpc), sourcing process, and what this product is not for."
>
  <Hero
    eyebrow="FAQ"
    title="Questions founders and AI builders ask first"
    subtitle="If you have a question that is not covered here, send it via the contact form. We will reply and may add it to this page."
  />

  <Section
    eyebrow="Browse by topic"
    title="Frequently asked questions"
    align="left"
  >
    <div class="space-y-10">
      {faqs.map((group) => (
        <div>
          <h3 class="text-xl font-bold mb-4 text-slate-900 dark:text-slate-100">{group.category}</h3>
          <div class="space-y-3">
            {group.items.map((item) => (
              <details class="group rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
                <summary class="flex cursor-pointer items-start justify-between gap-4 font-medium text-slate-900 dark:text-slate-100">
                  <span>{item.q}</span>
                  <span class="ml-auto inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-slate-300 text-slate-500 transition-transform group-open:rotate-45 dark:border-slate-700">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                  </span>
                </summary>
                <div class="mt-3 text-slate-600 dark:text-slate-400 leading-relaxed">
                  {item.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <CTA />
</PageLayout>
