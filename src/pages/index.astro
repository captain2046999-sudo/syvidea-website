---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import CTA from '../components/CTA.astro';
import ProductMock from '../components/ProductMock.astro';
import { AnimatedCard, AnimatedText, AnimatedLink, GlowingCard } from '../components/Animated';
import { brands, useCases } from '../data/brands';
import { sharedPlatform } from '../data/platform';
import { siteConfig } from '../data/site';
---
<PageLayout
  title="Syvidea — Local AI Workstation Sourcing & Advisory"
  description="Syvidea helps developers, creators and small teams choose and source selected local AI workstations from hardware partners. AMD Strix Halo / AI Max+ 395, 128GB unified memory."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-16 pb-24 sm:pt-24 sm:pb-32">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="glow-bg top-0 left-1/4 h-96 w-96 bg-neon-purple/20 animate-glow-pulse"></div>
    <div class="glow-bg top-20 right-1/4 h-80 w-80 bg-neon-cyan/15 animate-glow-pulse" style="animation-delay: -2s;"></div>
    <div class="glow-bg bottom-0 left-1/3 h-64 w-64 bg-neon-orange/10 animate-glow-pulse" style="animation-delay: -1s;"></div>

    <div class="container-page relative">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <div class="mb-6 inline-flex">
            <span class="badge">
              <span class="mr-1.5 inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-neon-purple"></span>
              Local AI Workstation Sourcing & Advisory
            </span>
          </div>
          <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
            <AnimatedText delay={0.1} class="gradient-text">Most mini PC brands sell specs.</AnimatedText>
            <br />
            <AnimatedText delay={0.2} class="text-white">We help you choose one for real AI workloads.</AnimatedText>
          </h1>
          <AnimatedText delay={0.3}>
            <p class="mt-6 text-lg text-slate-400 text-balance max-w-xl">
              Syvidea is a sourcing and advisory service for local AI workstations built on the AMD Strix Halo / AI Max+ 395 platform.
              We help you compare partner options (BOSGAME, PELAND, BITPC), match the configuration to your actual AI workflow,
              and coordinate quote-based ordering.
            </p>
          </AnimatedText>
          <div class="mt-8 flex flex-wrap gap-3">
            <AnimatedLink href="/request-quote" class="btn-primary inline-flex items-center">
              Request a configuration quote
              <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </AnimatedLink>
            <AnimatedLink href="/workstations" class="btn-secondary inline-flex items-center">
              Explore Workstations
            </AnimatedLink>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-slate-400">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              128GB unified memory
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              3 curated brands
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              Quote-based ordering
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-8 rounded-[3rem] bg-gradient-to-br from-neon-purple/20 via-neon-cyan/15 to-neon-orange/10 blur-3xl"></div>
          <div class="relative rounded-3xl border border-slate-800/60 bg-dark-900/50 shadow-2xl shadow-black/30 backdrop-blur-xl overflow-hidden">
            <ProductMock variant="hero" brand="BOSGAME" />
          </div>

          <div class="absolute -left-4 top-1/4 hidden rounded-2xl border border-neon-purple/30 bg-dark-900/80 px-4 py-3 shadow-xl shadow-neon-purple/20 backdrop-blur-xl sm:block">
            <div class="text-xs text-neon-purple/70">AI Performance</div>
            <div class="text-xl font-bold gradient-text-purple">50+ TOPS NPU</div>
          </div>

          <div class="absolute -right-4 bottom-1/4 hidden rounded-2xl border border-neon-cyan/30 bg-dark-900/80 px-4 py-3 shadow-xl shadow-neon-cyan/20 backdrop-blur-xl sm:block">
            <div class="text-xs text-neon-cyan/70">Unified Memory</div>
            <div class="text-xl font-bold gradient-text-cyan">128GB LPDDR5X</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y border-slate-800 bg-dark-900/30">
    <div class="container-page py-8">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-3">
        <div>
          <div class="text-3xl font-bold gradient-text-cyan">128<span class="text-lg">GB</span></div>
          <div class="mt-1 text-sm text-slate-400">Unified memory</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text-purple">2<span class="text-lg">TB</span></div>
          <div class="mt-1 text-sm text-slate-400">PCIe 4.0 SSD</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text-orange">3</div>
          <div class="mt-1 text-sm text-slate-400">Curated partner brands</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Positioning -->
  <Section
    eyebrow="What Syvidea is"
    title="Not a hardware brand. A sourcing and advisory service."
    subtitle="Syvidea does not manufacture workstations. We curate AMD Strix Halo / AI Max+ 395 partner options and help you choose, compare, and source the right one for your AI workflow."
    align="left"
  >
    <div class="grid gap-6 md:grid-cols-3">
      <AnimatedCard class="card" delay={0.1}>
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Other stores</div>
        <h3 class="mt-2 text-xl font-semibold text-slate-200">Generic mini PC listings</h3>
        <ul class="mt-4 space-y-2 text-slate-400">
          <li>• Hardware specs first, AI workflows second</li>
          <li>• Compete on chip names and lowest price</li>
          <li>• Add to cart, full online payment</li>
        </ul>
      </AnimatedCard>
      <GlowingCard class="card-neon" glowColor="purple" delay={0.2}>
        <div class="text-xs font-semibold uppercase tracking-wider text-neon-purple">Syvidea</div>
        <h3 class="mt-2 text-xl font-semibold text-white">Local AI infrastructure advisor</h3>
        <ul class="mt-4 space-y-2 text-slate-300">
          <li>• AI workflows first, then hardware fit</li>
          <li>• Curated partner options, not infinite SKUs</li>
          <li>• Quote-based ordering, with personal confirmation</li>
        </ul>
      </GlowingCard>
      <AnimatedCard class="card" delay={0.3}>
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Not a fit</div>
        <h3 class="mt-2 text-xl font-semibold text-slate-200">Be honest about trade-offs</h3>
        <ul class="mt-4 space-y-2 text-slate-400">
          <li>• Not the fastest CUDA image-generation box</li>
          <li>• Not for large-scale model training</li>
          <li>• Not a cheap office Mini PC</li>
        </ul>
      </AnimatedCard>
    </div>
  </Section>

  <!-- Use cases -->
  <Section
    eyebrow="Real AI workloads"
    title="Designed around how you actually run local AI"
    subtitle="The shared platform is selected to support these workflows. The exact software stack and validated model list will be confirmed with you during the quote."
  >
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {useCases.map((useCase, i) => (
        <AnimatedCard class="spec-card" delay={0.1 + i * 0.1}>
          <h3 class="text-lg font-semibold text-slate-200">{useCase.title}</h3>
          <p class="mt-2 text-slate-400">{useCase.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.models.slice(0, 3).map((m) => (
              <span class="text-xs rounded-lg bg-slate-800/50 border border-slate-700/50 px-2.5 py-1 text-slate-300">
                {m}
              </span>
            ))}
          </div>
        </AnimatedCard>
      ))}
    </div>
  </Section>

  <!-- Partner brands -->
  <Section
    eyebrow="Curated partner options"
    title="Three partner brands. One shared platform."
    subtitle="BOSGAME, PELAND, and BITPC all build on the same AMD Strix Halo / AI Max+ 395 platform. Differences live in chassis, I/O details, dimensions, wireless, thermals, BIOS, packaging, warranty, and supply batches."
  >
    <div class="grid gap-8 md:grid-cols-3">
      {brands.map((brand, i) => {
        const brandCardClass = brand.name === 'BOSGAME' ? 'card-neon' : brand.name === 'PELAND' ? 'card-cyan' : 'card-orange';
        const brandBadgeClass = brand.name === 'BOSGAME' ? 'badge' : brand.name === 'PELAND' ? 'badge-cyan' : 'badge-orange';
        const glowColor = brand.name === 'BOSGAME' ? 'purple' : brand.name === 'PELAND' ? 'cyan' : 'orange';
        return (
          <GlowingCard class={`group relative flex flex-col overflow-hidden rounded-3xl shadow-xl shadow-black/20 ${brandCardClass.replace('card-', 'border-slate-800/60 bg-dark-900/50 ')}`} glowColor={glowColor} delay={0.1 + i * 0.1}>
            <a href={`/workstations/${brand.slug}`} class="flex flex-1 flex-col">
              <div class="relative overflow-hidden">
                <ProductMock variant="card" brand={brand.name} />
                <div class="absolute top-4 left-4">
                  <span class={brandBadgeClass}>{brand.region}</span>
                </div>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="text-xl font-bold text-white">{brand.name}</h3>
                <p class="mt-1 text-sm text-slate-400">{brand.positioning}</p>
                <p class="mt-3 text-sm text-slate-300 flex-1">{brand.summary}</p>
                <div class="mt-5 flex items-center text-sm font-medium">
                  <span class={brand.name === 'BOSGAME' ? 'text-neon-purple' : brand.name === 'PELAND' ? 'text-neon-cyan' : 'text-neon-orange'}>View details</span>
                  <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              </div>
            </a>
          </GlowingCard>
        );
      })}
    </div>
  </Section>

  <!-- Shared platform summary -->
  <Section
    eyebrow="Shared platform"
    title="One specification, three partners"
    subtitle="A compact local AI workstation platform built around AMD Strix Halo, high-bandwidth LPDDR5X memory, dual PCIe 4.0 SSD slots and modern high-speed I/O."
  >
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <AnimatedCard class="spec-card" delay={0.1}>
        <div class="text-xs font-semibold uppercase tracking-wider text-neon-purple">Processor</div>
        <div class="mt-3 text-2xl font-bold gradient-text-purple">{sharedPlatform.processor.name}</div>
        <p class="mt-2 text-sm text-slate-400">
          {sharedPlatform.processor.cores} • {sharedPlatform.processor.boost}
        </p>
      </AnimatedCard>
      <AnimatedCard class="spec-card" delay={0.2}>
        <div class="text-xs font-semibold uppercase tracking-wider text-neon-cyan">Memory</div>
        <div class="mt-3 text-2xl font-bold gradient-text-cyan">{sharedPlatform.memory.capacity}</div>
        <p class="mt-2 text-sm text-slate-400">
          {sharedPlatform.memory.type} • {sharedPlatform.memory.bandwidth}
        </p>
      </AnimatedCard>
      <AnimatedCard class="spec-card" delay={0.3}>
        <div class="text-xs font-semibold uppercase tracking-wider text-neon-orange">Storage</div>
        <div class="mt-3 text-2xl font-bold gradient-text-orange">{sharedPlatform.storage.capacity}</div>
        <p class="mt-2 text-sm text-slate-400">
          {sharedPlatform.storage.slots}
        </p>
      </AnimatedCard>
      <AnimatedCard class="spec-card" delay={0.4}>
        <div class="text-xs font-semibold uppercase tracking-wider text-neon-pink">Graphics</div>
        <div class="mt-3 text-2xl font-bold gradient-text">{sharedPlatform.graphics.integrated}</div>
        <p class="mt-2 text-sm text-slate-400">
          {sharedPlatform.graphics.architecture}
        </p>
      </AnimatedCard>
    </div>
    <div class="mt-10 text-center">
      <AnimatedLink href={`/workstations/${sharedPlatform.slug}`} class="btn-primary inline-flex items-center">
        See the full shared platform spec
        <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </AnimatedLink>
    </div>
  </Section>

  <!-- How it works (brief) -->
  <Section
    eyebrow="How it works"
    title="From inquiry to delivery, in four steps"
    subtitle="Quote-based ordering. No add-to-cart, no online full-payment checkout."
  >
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { step: '1', title: 'Submit a request', desc: 'Tell us your use case, destination, and preferred partner brand via the Tally form.' },
        { step: '2', title: 'Receive a quote', desc: 'We confirm configuration, availability, and a written quote for your destination.' },
        { step: '3', title: 'Confirm and pay', desc: 'Approve the quote and arrange payment via a payment link or deposit.' },
        { step: '4', title: 'Delivery & support', desc: 'We coordinate shipment and share setup resources.' },
      ].map((s, i) => (
        <AnimatedCard class="card relative overflow-hidden" delay={0.1 + i * 0.1}>
          <div class="absolute top-0 right-0 h-20 w-20 rounded-bl-full bg-gradient-to-br from-neon-purple/20 to-transparent"></div>
          <div class="relative">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-neon-purple to-neon-pink text-white font-bold shadow-lg shadow-neon-purple/30">
                {s.step}
              </span>
              <h3 class="text-lg font-semibold text-slate-200">{s.title}</h3>
            </div>
            <p class="mt-4 text-slate-400">{s.desc}</p>
          </div>
        </AnimatedCard>
      ))}
    </div>
    <div class="mt-10 text-center">
      <AnimatedLink href="/how-it-works" class="btn-secondary inline-flex items-center">Read the full process</AnimatedLink>
    </div>
  </Section>

  <CTA />
</PageLayout>
