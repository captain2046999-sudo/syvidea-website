---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import CTA from '../components/CTA.astro';
import ProductMock from '../components/ProductMock.astro';

import { useCases } from '../data/brands';
---
<PageLayout
  title="Syvidea - Local AI Workstation Sourcing & Advisory"
  description="Syvidea builds and delivers local AI workstations powered by AMD Strix Halo / AI Max+ 395. Run 70B-class models locally with 128GB unified memory."
>
  <section class="relative overflow-hidden pt-4 pb-4 sm:pt-6 sm:pb-8">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="glow-bg top-0 left-1/4 h-72 w-72 bg-neon-purple/20 animate-glow-pulse sm:h-96 sm:w-96"></div>
    <div class="glow-bg top-20 right-1/4 h-64 w-64 bg-neon-cyan/15 animate-glow-pulse sm:h-80 sm:w-80" style="animation-delay: -2s;"></div>
    <div class="glow-bg bottom-0 left-1/3 h-48 w-48 bg-neon-orange/10 animate-glow-pulse sm:h-64 sm:w-64" style="animation-delay: -1s;"></div>

    <div class="container-page relative">
      <div class="grid items-center gap-8 lg:grid-cols-[45%_55%] lg:gap-12">
        <div>
          <div class="mb-6 inline-flex">
            <span class="badge">
              <span class="mr-1.5 inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-neon-purple"></span>
              Local AI Workstation Sourcing & Advisory
            </span>
          </div>
          <h1 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            <span class="gradient-text animate-fade-in-up">Run 70B-class AI models locally</span>
            <br />
            <span class="text-white animate-fade-in-up animation-delay-200">-- without recurring cloud GPU bills.</span>
          </h1>
          <div class="animate-fade-in-up animation-delay-300">
            <p class="mt-4 text-base text-slate-400 text-balance max-w-xl sm:text-lg">
              Syvidea builds and delivers local AI workstations powered by AMD Strix Halo,
              mapping inference requirements to optimized configurations across our S1 Base,
              S1 Pro, and S1 Max models.
            </p>
          </div>
          <div class="animate-fade-in-up animation-delay-300">
            <p class="mt-2 text-sm text-neon-cyan font-medium max-w-xl">
              Stop paying for cloud GPUs. Get dedicated local inference infrastructure.
            </p>
          </div>
          <div class="animate-fade-in-up animation-delay-400">
            <div class="mt-4 p-3 rounded-xl border border-neon-purple/30 bg-dark-900/50 max-w-xl">
              <p class="text-sm font-medium text-neon-purple">What this means for you:</p>
              <p class="mt-1.5 text-sm text-slate-400">
                You receive a structured configuration proposal instead of manually comparing specs.
                All recommendations are manually reviewed and validated within 24-48 hours.
              </p>
            </div>
          </div>
          <div class="animate-fade-in-up animation-delay-400">
            <div class="mt-4 grid grid-cols-2 gap-3 max-w-xl">
              <div class="flex items-center gap-3 p-3 rounded-xl border border-neon-purple/20 bg-dark-900/30">
                <svg class="h-5 w-5 text-neon-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                  <line x1="8" y1="21" x2="16" y2="21" />
                  <line x1="12" y1="17" x2="12" y2="21" />
                </svg>
                <div>
                  <div class="text-sm font-bold text-white">128GB</div>
                  <div class="text-xs text-slate-400">Unified Memory</div>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl border border-neon-cyan/20 bg-dark-900/30">
                <svg class="h-5 w-5 text-neon-cyan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
                <div>
                  <div class="text-sm font-bold text-white">50+ TOPS</div>
                  <div class="text-xs text-slate-400">NPU AI</div>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl border border-neon-orange/20 bg-dark-900/30">
                <svg class="h-5 w-5 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
                <div>
                  <div class="text-sm font-bold text-white">3 Models</div>
                  <div class="text-xs text-slate-400">S1 Series</div>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl border border-neon-green/20 bg-dark-900/30">
                <svg class="h-5 w-5 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                  <circle cx="8" cy="21" r="2" />
                  <circle cx="16" cy="21" r="2" />
                </svg>
                <div>
                  <div class="text-sm font-bold text-white">AMD</div>
                  <div class="text-xs text-slate-400">Strix Halo</div>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex flex-col sm:flex-row gap-3">
            <a href="/request-quote" class="btn-primary w-full sm:inline-flex items-center justify-center">
              Request a configuration quote
              <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
            <a href="/workstations" class="btn-secondary w-full sm:inline-flex items-center justify-center">
              Explore Workstations
            </a>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-slate-400">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              128GB unified memory
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              3 S1 Series models
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              Quote-based ordering
            </div>
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-slate-400">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
              Manual configuration review
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-cyan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              24-48h response time
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
              Private data, local control
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
              </svg>
              Workload-based optimization
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-8 rounded-[3rem] bg-gradient-to-br from-neon-purple/20 via-neon-cyan/15 to-neon-orange/10 blur-3xl"></div>
          <div class="relative rounded-3xl border border-slate-800/60 bg-dark-900/50 shadow-2xl shadow-black/30 backdrop-blur-xl overflow-hidden">
            <ProductMock variant="hero" brand="Syvidea S1 Pro" />
          </div>

          <div class="absolute -left-4 top-1/4 hidden rounded-2xl border border-neon-purple/30 bg-dark-900/80 px-4 py-3 shadow-xl shadow-neon-purple/20 backdrop-blur-xl sm:block">
            <div class="text-xs text-neon-purple/70">AI Performance</div>
            <div class="text-xl font-bold gradient-text-purple">50+ TOPS NPU</div>
          </div>

          <div class="absolute -right-4 bottom-1/4 hidden rounded-2xl border border-neon-cyan/30 bg-dark-900/80 px-4 py-3 shadow-xl shadow-neon-cyan/20 backdrop-blur-xl sm:block">
            <div class="text-xs text-neon-cyan/70">Unified Memory</div>
            <div class="text-xl font-bold gradient-text-cyan">128GB LPDDR5X</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-800 bg-dark-900/30">
    <div class="container-page py-4">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-3">
        <div>
          <div class="text-3xl font-bold gradient-text-cyan">128<span class="text-lg">GB</span></div>
          <div class="mt-1 text-sm text-slate-400">Unified memory</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text-purple">2<span class="text-lg">TB</span></div>
          <div class="mt-1 text-sm text-slate-400">PCIe 4.0 SSD</div>
        </div>
        <div>
          <div class="text-3xl font-bold gradient-text-orange">3</div>
          <div class="mt-1 text-sm text-slate-400">Curated partner brands</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-4 bg-gradient-to-r from-neon-purple/10 via-dark-900 to-neon-cyan/10">
    <div class="container-page">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-neon-orange/20 flex items-center justify-center">
            <svg class="h-6 w-6 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
          </div>
          <div>
            <div class="text-sm font-medium text-white">Why Not Cloud?</div>
            <div class="text-xs text-slate-400">CAPEX vs OPEX: One-time cost vs recurring cloud GPU bills</div>
          </div>
        </div>
        <div class="flex items-center gap-6 text-sm">
          <div class="text-center">
            <div class="text-lg font-bold gradient-text-orange">~$3-4k</div>
            <div class="text-xs text-slate-400">One-time cost</div>
          </div>
          <div class="w-px h-8 bg-slate-700"></div>
          <div class="text-center">
            <div class="text-lg font-bold text-slate-400">~$500+/mo</div>
            <div class="text-xs text-slate-400">Cloud GPU</div>
          </div>
          <div class="w-px h-8 bg-slate-700"></div>
          <div class="text-center">
            <div class="text-lg font-bold gradient-text-green">6-8 months</div>
            <div class="text-xs text-slate-400">ROI break-even</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Section
    eyebrow="Why Syvidea?"
    title="Three reasons to work with us"
    subtitle="We don't just sell hardware. We help you build local AI infrastructure that actually works."
  >
    <div class="grid gap-6 md:grid-cols-3">
      <div class="card text-center animate-fade-in-up">
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-neon-purple/20 mb-4">
          <svg class="h-7 w-7 text-neon-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
            <polyline points="22 4 12 14.01 9 11.01" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white">Curated Selection</h3>
        <p class="mt-2 text-sm text-slate-400">We hand-pick ODMs, we don't resell everything. Quality over quantity.</p>
      </div>
      <div class="card text-center animate-fade-in-up animation-delay-200">
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-neon-cyan/20 mb-4">
          <svg class="h-7 w-7 text-neon-cyan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <polyline points="21 15 16 10 5 21" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white">Workload Mapping</h3>
        <p class="mt-2 text-sm text-slate-400">We match your AI task to the right hardware, not just specs on a page.</p>
      </div>
      <div class="card text-center animate-fade-in-up animation-delay-300">
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-neon-green/20 mb-4">
          <svg class="h-7 w-7 text-neon-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white">Human Validation</h3>
        <p class="mt-2 text-sm text-slate-400">Every config is checked by our team before you pay.</p>
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Your AI workstation partner"
    title="We help you source the right local AI workstation"
    subtitle="Syvidea curates AMD Strix Halo / AI Max+ 395 partner options and helps you choose, compare, and source the right one for your AI workflow."
    align="left"
  >
    <p class="text-sm text-slate-400 mb-6">Every configuration is validated against your workload before quoting. We evaluate memory, compute, and workflow requirements to match the right hardware.</p>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="card animate-fade-in-up">
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-400">Other stores</div>
        <h3 class="mt-2 text-xl font-semibold text-slate-200">Generic mini PC listings</h3>
        <ul class="mt-4 space-y-2 text-slate-400">
          <li>- Hardware specs first, AI workflows second</li>
          <li>- Compete on chip names and lowest price</li>
          <li>- Add to cart, full online payment</li>
        </ul>
      </div>
      <div class="card-neon animate-fade-in-up animation-delay-200">
        <div class="text-xs font-semibold uppercase tracking-wider text-neon-purple">Syvidea</div>
        <h3 class="mt-2 text-xl font-semibold text-white">Local AI infrastructure advisor</h3>
        <ul class="mt-4 space-y-2 text-slate-300">
          <li>- AI workflows first, then hardware fit</li>
          <li>- Curated partner options, not infinite SKUs</li>
          <li>- Quote-based ordering, with personal confirmation</li>
        </ul>
      </div>
      <div class="card animate-fade-in-up animation-delay-300">
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-400">Focus</div>
        <h3 class="mt-2 text-xl font-semibold text-slate-200">Optimized for local AI</h3>
        <ul class="mt-4 space-y-2 text-slate-400">
          <li>- 128GB unified memory for large models</li>
          <li>- Integrated NPU for AI acceleration</li>
          <li>- Compact form factor for desk deployment</li>
        </ul>
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Real AI workloads"
    title="Designed around how you actually run local AI"
    subtitle="The shared platform is selected to support these workflows. The exact software stack and validated model list will be confirmed with you during the quote."
  >
    <p class="text-sm text-slate-400 mb-6">Each use case maps to specific hardware optimization requirements. We evaluate your workload intensity and memory demand to recommend the right configuration.</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {useCases.map((useCase, i) => {
        const gradientColors = [
          'from-neon-purple to-neon-pink',
          'from-neon-cyan to-neon-blue',
          'from-neon-orange to-neon-yellow',
          'from-neon-green to-neon-cyan',
          'from-neon-pink to-neon-orange',
          'from-neon-blue to-neon-purple',
        ];
        return (
          <div class="group relative overflow-hidden rounded-3xl border border-slate-800/60 bg-dark-900/50 p-6 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 animate-fade-in-up">
            <div class="relative h-32 mb-6 overflow-hidden rounded-2xl bg-dark-800/50">
              <img
                src={`https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=${encodeURIComponent(useCase.imagePrompt)}&image_size=landscape_16_9`}
                alt={useCase.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-999 via-dark-999/50 to-transparent"></div>
              <div class="absolute bottom-3 left-3">
                <span class={`inline-flex items-center gap-2 text-xs font-medium text-white`}>
                  <span class={`h-1.5 w-1.5 rounded-full bg-gradient-to-r ${gradientColors[i % gradientColors.length]}`}></span>
                  {useCase.title}
                </span>
              </div>
            </div>
            <h3 class="text-lg font-semibold text-slate-200">{useCase.title}</h3>
            <p class="mt-2 text-sm text-slate-400">{useCase.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {useCase.models.slice(0, 3).map((m) => (
                <span class="text-xs rounded-lg bg-slate-800/50 border border-slate-700/50 px-2.5 py-1 text-slate-300">
                  {m}
                </span>
              ))}
            </div>
            <div class="mt-4 text-xs text-slate-400">
              Recommended: {useCase.recommended}
            </div>
          </div>
        );
      })}
    </div>
  </Section>

  <Section
    eyebrow="S1 Series"
    title="Syvidea S1 Series Workstations"
    subtitle="Built on the AMD Strix Halo / AI Max+ 395 platform with 128GB unified memory and 2TB NVMe SSD. Syvidea evaluates your AI workload and recommends the optimal configuration."
  >
    <div class="card border border-neon-purple/30 bg-dark-900/60 rounded-3xl p-8">
      <div class="grid gap-6 lg:grid-cols-3">
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-neon-purple/20 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-neon-purple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <line x1="9" y1="9" x2="15" y2="9" />
              <line x1="9" y1="15" x2="15" y2="15" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">128GB Unified Memory</h3>
          <p class="text-sm text-slate-400">Enables local 70B model inference</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-neon-cyan/20 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-neon-cyan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2" />
              <line x1="12" y1="22" x2="12" y2="15.5" />
              <line x1="22" y1="8.5" x2="12" y2="15.5" />
              <line x1="2" y1="8.5" x2="12" y2="15.5" />
              <line x1="2" y1="15.5" x2="12" y2="15.5" />
              <line x1="22" y1="15.5" x2="12" y2="15.5" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">50 TOPS NPU</h3>
          <p class="text-sm text-slate-400">Accelerated AI inference</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-neon-orange/20 flex items-center justify-center mb-4">
            <svg class="h-8 w-8 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
