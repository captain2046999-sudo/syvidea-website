---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import CTA from '../components/CTA.astro';
import { brands } from '../data/brands';
---
<PageLayout
  title="Availability & Lead Times — Syvidea"
  description="Understand how supply batches, partner brand availability, and delivery windows work for Syvidea's curated local AI workstation options."
>
  <section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="absolute inset-0 bg-dark-999"></div>
    <div class="absolute inset-0 cyber-bg"></div>
    <div class="absolute inset-0 grid-bg opacity-20"></div>
    <div class="glow-bg top-10 left-1/3 h-96 w-96 bg-neon-orange/15 animate-glow-pulse"></div>

    <div class="container-page relative">
      <div class="mx-auto max-w-3xl text-center">
        <div class="mb-5 flex justify-center">
          <span class="badge">Action</span>
        </div>
        <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl gradient-text">
          Ask availability
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 text-balance">
          Supply and lead times vary by partner brand, configuration, and destination. This page explains
          how availability works and how to request current stock status.
        </p>
      </div>
    </div>
  </section>

  <Section
    eyebrow="How availability works"
    title="Supply batches, not infinite inventory"
    align="left"
  >
    <div class="card">
      <p class="text-slate-300 leading-relaxed">
        Syvidea does not hold inventory. Each partner brand produces and releases workstations in supply
        batches. When a batch is allocated, the next batch may have a different lead time, port revision,
        or firmware version.
      </p>
      <p class="mt-4 text-slate-400 leading-relaxed">
        This is why we use a quote-based flow: before you commit, we confirm whether the preferred brand
        has current or upcoming allocation for your destination.
      </p>
    </div>
  </Section>

  <Section
    eyebrow="Partner brands"
    title="Availability by option"
    align="left"
  >
    <div class="grid gap-6 md:grid-cols-3">
      {brands.map((brand) => (
        <div class="card">
          <h3 class="text-xl font-bold text-white">{brand.name}</h3>
          <p class="mt-1 text-sm text-slate-400">{brand.positioning}</p>
          <p class="mt-3 text-sm text-slate-300">{brand.note}</p>
          <div class="mt-5">
            <a href="/request-quote" class="text-sm font-medium text-neon-purple">Request availability →</a>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section
    eyebrow="What affects lead time"
    title="Factors that change delivery windows"
    align="left"
  >
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="spec-card">
        <h3 class="font-semibold text-slate-200">Partner brand allocation</h3>
        <p class="mt-1 text-sm text-slate-400">Each brand releases units in batches. Allocation timing is the primary driver.</p>
      </div>
      <div class="spec-card">
        <h3 class="font-semibold text-slate-200">Destination country</h3>
        <p class="mt-1 text-sm text-slate-400">Shipping, customs, and certification requirements vary by region.</p>
      </div>
      <div class="spec-card">
        <h3 class="font-semibold text-slate-200">Configuration</h3>
        <p class="mt-1 text-sm text-slate-400">Storage size, OS pre-install, and accessories can affect batch availability.</p>
      </div>
      <div class="spec-card">
        <h3 class="font-semibold text-slate-200">Shipping method</h3>
        <p class="mt-1 text-sm text-slate-400">Standard, expedited, and freight options have different lead times.</p>
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Get current status"
    title="Request availability"
    align="left"
  >
    <div class="card text-center">
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">
        Send us your preferred partner brand and destination. We will reply with current batch status,
        estimated lead time, and next steps.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/request-quote" class="btn-primary">Ask Availability</a>
        <a href="/how-it-works" class="btn-secondary">How It Works</a>
      </div>
    </div>
  </Section>

  <CTA />
</PageLayout>
