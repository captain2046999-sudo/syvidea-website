---
import { siteConfig } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="border-t border-slate-800/60 bg-dark-900/50">
  <div class="container-page py-12">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-5">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 font-bold text-lg">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-neon-purple to-neon-pink text-white font-bold shadow-lg shadow-neon-purple/30">
            S
          </span>
          <span class="text-white">Syvidea</span>
        </a>
        <p class="mt-3 text-sm text-slate-400">
          {siteConfig.shortDescription}
        </p>
        <p class="mt-2 text-sm text-slate-500">
          {siteConfig.region}
        </p>
      </div>

      <!-- Workstations -->
      <div>
        <h3 class="text-sm font-semibold text-slate-200">Workstations</h3>
        <ul class="mt-3 space-y-2">
          {siteConfig.footer.product.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-neon-purple">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-slate-200">Resources</h3>
        <ul class="mt-3 space-y-2">
          {siteConfig.footer.resources.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-neon-cyan">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-slate-200">Company</h3>
        <ul class="mt-3 space-y-2">
          {siteConfig.footer.company.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-neon-orange">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-slate-200">Legal</h3>
        <ul class="mt-3 space-y-2">
          {siteConfig.footer.legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-neon-purple">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-800/60 pt-8 md:flex-row">
      <p class="text-sm text-slate-500">
        © {year} {siteConfig.name}. All rights reserved. {siteConfig.region}.
      </p>
      <p class="text-sm text-slate-500">
        Not a hardware manufacturer. Sourcing & advisory only.
      </p>
    </div>
  </div>
</footer>
