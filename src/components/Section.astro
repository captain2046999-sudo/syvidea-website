---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, subtitle, align = 'center' } = Astro.props;
---
<section class="section">
  <div class="container-page">
    <div class:list={[align === 'center' && "text-center", "max-w-3xl", align === 'center' && "mx-auto"]}>
      {eyebrow && <span class="badge mb-3">{eyebrow}</span>}
      <h2 class="section-title">{title}</h2>
      {subtitle && <p class="section-subtitle">{subtitle}</p>}
    </div>
    <div class="mt-12">
      <slot />
    </div>
  </div>
</section>
