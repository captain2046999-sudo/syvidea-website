---
export interface Props {
  variant?: 'hero' | 'card' | 'detail';
  brand?: string;
}
const { variant = 'hero', brand = '' } = Astro.props;

const brandColors: Record<string, { primary: string; secondary: string; accent: string; name: string }> = {
  bosgame: { primary: '#a855f7', secondary: '#ec4899', accent: '#06b6d4', name: 'BOSGAME' },
  peland: { primary: '#06b6d4', secondary: '#3b82f6', accent: '#10b981', name: 'PELAND' },
  bitpc: { primary: '#f97316', secondary: '#eab308', accent: '#ef4444', name: 'BITPC' },
  default: { primary: '#a855f7', secondary: '#ec4899', accent: '#06b6d4', name: 'AI WORKSTATION' },
};

const brandKey = brand.toLowerCase() as keyof typeof brandColors;
const colors = brandColors[brandKey] || brandColors.default;
---
<div
  class:list={[
    'relative overflow-hidden',
    variant === 'hero' && 'aspect-[16/10] w-full',
    variant === 'card' && 'aspect-[4/3] w-full',
    variant === 'detail' && 'aspect-video w-full',
  ]}
  style={`--c1:${colors.primary};--c2:${colors.secondary};--c3:${colors.accent};`}
>
  <div class="absolute inset-0 bg-gradient-to-br from-dark-999 via-dark-950 to-dark-900"></div>

  <div class="absolute -top-20 -left-20 h-72 w-72 rounded-full opacity-25 blur-3xl animate-glow-pulse" style={`background:${colors.primary};`}></div>
  <div class="absolute -bottom-20 -right-20 h-72 w-72 rounded-full opacity-20 blur-3xl animate-glow-pulse" style={`background:${colors.secondary};animation-delay:-2s;`}></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-96 w-96 rounded-full opacity-10 blur-3xl" style={`background:${colors.accent};`}></div>

  <div class="absolute inset-0 grid-bg opacity-20"></div>

  <div class="absolute inset-0 flex items-center justify-center">
    <div class="relative w-3/4 max-w-md animate-float">
      <div class="relative">
        <div class="aspect-[5/4] rounded-3xl border border-slate-800/60 bg-gradient-to-br from-dark-800/80 to-dark-900/90 shadow-2xl shadow-black/40 backdrop-blur-sm" style={`box-shadow:0 0 30px ${colors.primary}15, 0 0 60px ${colors.primary}08, 0 25px 50px -12px rgba(0,0,0,0.5);`}>
          <div class="absolute inset-0 rounded-3xl overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent"></div>
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
          </div>

          <div class="absolute top-4 left-4 right-4 flex items-center justify-between">
            <div class="flex gap-1.5">
              <div class="h-2 w-2 rounded-full animate-pulse" style={`background:${colors.primary};box-shadow:0 0 8px ${colors.primary};`}></div>
              <div class="h-2 w-2 rounded-full" style={`background:${colors.secondary};box-shadow:0 0 6px ${colors.secondary};`}></div>
              <div class="h-2 w-2 rounded-full" style={`background:${colors.accent};box-shadow:0 0 6px ${colors.accent};`}></div>
            </div>
            <div class="text-[10px] font-bold tracking-wider text-slate-500">
              {colors.name}
            </div>
          </div>

          <div class="absolute inset-x-8 top-12 bottom-8 space-y-3">
            <div class="flex items-center gap-2">
              <div class="h-1.5 w-1/4 rounded-full" style={`background:${colors.primary};box-shadow:0 0 10px ${colors.primary};`}></div>
              <div class="h-1 w-1/3 rounded-full bg-slate-700"></div>
            </div>

            <div class="h-2 w-1/2 rounded-md bg-slate-800/50"></div>

            <div class="grid grid-cols-2 gap-3 pt-4">
              <div class="rounded-xl border border-slate-700/40 bg-dark-800/60 p-3 backdrop-blur-sm" style={`box-shadow:inset 0 0 20px ${colors.primary}08;`}>
                <div class="text-[10px] text-slate-500 uppercase tracking-wider">Memory</div>
                <div class="text-lg font-bold" style={`background:linear-gradient(90deg,${colors.primary},${colors.secondary});-webkit-background-clip:text;background-clip:text;color:transparent;`}>128GB</div>
              </div>
              <div class="rounded-xl border border-slate-700/40 bg-dark-800/60 p-3 backdrop-blur-sm" style={`box-shadow:inset 0 0 20px ${colors.accent}08;`}>
                <div class="text-[10px] text-slate-500 uppercase tracking-wider">Storage</div>
                <div class="text-lg font-bold" style={`background:linear-gradient(90deg,${colors.secondary},${colors.accent});-webkit-background-clip:text;background-clip:text;color:transparent;`}>2TB</div>
              </div>
            </div>

            <div class="flex items-center gap-2 pt-2">
              <div class="text-[10px] text-slate-500">AI</div>
              <div class="flex-1 h-1.5 rounded-full bg-dark-800 overflow-hidden">
                <div class="h-full w-4/5 rounded-full animate-glow-pulse" style={`background:linear-gradient(90deg,${colors.primary},${colors.accent});box-shadow:0 0 10px ${colors.primary};`}></div>
              </div>
              <div class="text-[10px] font-bold" style={`color:${colors.primary};`}>50 TOPS</div>
            </div>
          </div>

          <div class="absolute right-4 top-1/2 -translate-y-1/2 flex flex-col gap-2">
            <div class="h-8 w-1 rounded-full" style={`background:linear-gradient(180deg,${colors.primary},${colors.accent});`}></div>
            <div class="h-6 w-1 rounded-full" style={`background:linear-gradient(180deg,${colors.secondary},${colors.accent});`}></div>
            <div class="h-4 w-1 rounded-full" style={`background:${colors.accent};`}></div>
          </div>
        </div>

        <div class="absolute -right-6 -top-6 h-20 w-20 rounded-2xl border border-slate-800/40 bg-dark-800/50 shadow-xl shadow-black/30 backdrop-blur-sm animate-float-delayed" style={`box-shadow:0 0 20px ${colors.primary}15, 0 8px 30px -10px rgba(0,0,0,0.5);`}></div>
        <div class="absolute -left-8 bottom-4 h-14 w-14 rounded-xl border border-slate-800/40 bg-dark-800/50 shadow-xl shadow-black/30 backdrop-blur-sm animate-float" style={{ animationDelay: '-1.5s', boxShadow: `0 0 15px ${colors.accent}12, 0 6px 20px -8px rgba(0,0,0,0.5)` }}></div>
      </div>
    </div>
  </div>

  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-dark-999 to-transparent"></div>
</div>
