---
import { siteConfig } from '../data/site';

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
};
---
<header class="sticky top-0 z-40 w-full border-b border-slate-800/60 bg-dark-999/80 backdrop-blur-lg">
  <div class="container-page flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-neon-purple to-neon-pink text-white font-bold shadow-lg shadow-neon-purple/30">
        S
      </span>
      <span class="tracking-tight text-white">Syvidea</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-2 text-sm font-medium rounded-md transition-colors',
            isActive(item.href)
              ? 'text-neon-purple'
              : 'text-slate-400 hover:text-white',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/request-quote" class="hidden sm:inline-flex btn-primary text-sm">
        Request a configuration quote
      </a>
      <button
        id="mobile-menu-toggle"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-slate-400 hover:bg-dark-800"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800/60 bg-dark-900/95 backdrop-blur-lg">
    <div class="container-page py-3 space-y-1">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-3 py-2 text-sm font-medium rounded-md',
            isActive(item.href)
              ? 'bg-neon-purple/10 text-neon-purple'
              : 'text-slate-400 hover:bg-dark-800 hover:text-white',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="/request-quote" class="block px-3 py-2 text-sm font-medium rounded-md bg-gradient-to-r from-neon-purple to-neon-pink text-white text-center shadow-lg shadow-neon-purple/30">
        Request a configuration quote
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
