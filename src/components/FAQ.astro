---
export interface Props {
  title: string;
  items: Array<{ q: string; a: string }>;
  defaultOpen?: boolean;
}
const { title, items, defaultOpen = false } = Astro.props;
---
<section class="section">
  <div class="container-page max-w-4xl">
    {title && <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-8">{title}</h2>}
    <div class="space-y-3">
      {items.map((item, idx) => (
        <details class="group rounded-2xl border border-slate-800 bg-dark-900/60 p-5 backdrop-blur-sm transition-all duration-300 hover:border-neon-purple/30" open={defaultOpen && idx === 0}>
          <summary class="flex cursor-pointer items-start justify-between gap-4 font-medium text-white">
            <span>{item.q}</span>
            <span class="ml-auto inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-slate-700 text-slate-400 transition-transform group-open:rotate-45 group-open:border-neon-purple group-open:text-neon-purple">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </span>
          </summary>
          <div class="mt-3 text-slate-400 leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
