{
  "version": 2,
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "trailingSlash": false,
  "redirects": [
    { "source": "/workstations/amd-strix-halo-platform", "destination": "/workstations/platform", "permanent": true },
    { "source": "/workstations/amd-strix-halo-platform/:path*", "destination": "/workstations/platform/:path*", "permanent": true },
    { "source": "/workstations/bosgame-ai-max-395", "destination": "/workstations/bosgame", "permanent": true },
    { "source": "/workstations/peland-ai-max-395", "destination": "/workstations/peland", "permanent": true },
    { "source": "/workstations/bitpc-ai-max-395", "destination": "/workstations/bitpc", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
